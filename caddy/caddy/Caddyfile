homarr.{$MY_DOMAIN} {
	reverse_proxy homarr:7575

	tls {
		dns porkbun {
			api_key {$PORKBUN_API_KEY}
			api_secret_key {$PORKBUN_API_SECRET_KEY}
		}
		# resolvers {$DNS_RESOLVER} # Custom DNS provider if behind a VPN
	}
}

nextcloud.{$MY_DOMAIN} {
	reverse_proxy nextcloud-aio-apache:11000

	tls {
		dns porkbun {
			api_key {$PORKBUN_API_KEY}
			api_secret_key {$PORKBUN_API_SECRET_KEY}
		}
		# resolvers {$DNS_RESOLVER} # Custom DNS provider if behind a VPN
	}
}
